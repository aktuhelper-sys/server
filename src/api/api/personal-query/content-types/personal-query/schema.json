{
  "kind": "collectionType",
  "collectionName": "personal_queries",
  "info": {
    "singularName": "personal-query",
    "pluralName": "personal-queries",
    "displayName": "personal-query"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string"
    },
    "description": {
      "type": "text"
    },
    "category": {
      "type": "enumeration",
      "enum": [
        "academics",
        "career",
        "college-life",
        "General Query"
      ]
    },
    "fromUser": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::user-profile.user-profile",
      "inversedBy": "sentPersonalQueries"
    },
    "toUser": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::user-profile.user-profile",
      "inversedBy": "receivedPersonalQueries"
    },
    "isRead": {
      "type": "boolean",
      "default": true
    },
    "readAt": {
      "type": "datetime"
    },
    "isNew": {
      "type": "boolean",
      "default": false
    },
    "personal_query_answers": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::personal-query-answer.personal-query-answer",
      "mappedBy": "personal_query"
    },
    "attachment": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    },
    "amount_paise": {
      "type": "integer"
    },
    "deadline_hours": {
      "type": "integer"
    },
    "deadline_label": {
      "type": "string"
    },
    "razorpay_order_id": {
      "type": "string"
    },
    "razorpay_payment_id": {
      "type": "string"
    },
    "payment_status": {
      "type": "string"
    },
    "deadline_at": {
      "type": "datetime"
    },
    "accept_deadline": {
      "type": "datetime"
    },
    "transfer_done": {
      "type": "boolean",
      "default": false
    },
    "answered_at": {
      "type": "datetime"
    },
    "settlement_type": {
      "type": "enumeration",
      "enum": [
        "accepted",
        "rejected",
        "expired",
        "auto_accepted"
      ]
    },
    "transfer_id": {
      "type": "string"
    },
    "refund_id": {
      "type": "string"
    },
    "transactions": {
      "type": "relation",
      "relation": "oneToMany",
      "target": "api::transaction.transaction",
      "mappedBy": "personal_query"
    },
    "query_status": {
      "type": "string"
    },
    "review_deadline_at": {
      "type": "datetime"
    },
    "processing_started_at": {
      "type": "datetime"
    }
  }
}
